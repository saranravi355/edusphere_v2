# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.vercel

# local-only backups and one-off dev utilities (not part of the app/build)
prisma/dev_backup.db
generate-pdf.js

# stray build-cache copies and editor backup files from local dev sessions
.next_OLD*/
*.stale_bak
*.stale_bak2
*.stale_bak3
sync_test_marker.txt
src/lib/session_test_fresh.ts

# generated deliverable docs, not part of the app source
edusphere360_changelog.pdf
edusphere360_feature_overview.pdf
edusphere360_feature_overview_v2.pdf
~$*
