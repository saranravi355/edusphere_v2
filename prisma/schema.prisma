generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   @default("password123")
  name      String
  role      String   @default("PARENT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile   Teacher?
  parentProfile    Parent?
  studentProfile   Student?          @relation("StudentUser")
  messagesSent     Message[]         @relation("Sender")
  messagesRecv     Message[]         @relation("Receiver")
  notifications    Notification[]
  assetCheckouts   AssetCheckout[]
  resourceBookings ResourceBooking[]
}

model Teacher {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects         String // comma separated or related table
  qualifications   String?
  yearsExperience  Int?
  cpdHours         Int      @default(0)
  
  classes          Classroom[]
  homeworks        Homework[]
  behaviorIncidents BehaviorIncident[]
  clubs            Club[]
  leaveRequests    LeaveRequest[]
  quizzes          Quiz[]
  moderatedQuizzes Quiz[] @relation("ModeratedQuizzes")
  timetable        TimetableEntry[]
  iepCaseloads     IEPPlan[] @relation("IEPCaseloads")
  pdRecords        PDRecord[]
  observations     Observation[] @relation("ObservedTeacher")
  lessonPlans      LessonPlan[]
}

model Parent {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone            String?
  address          String?
  emergencyContact String?
  students         Student[]
}

model Student {
  id               String       @id @default(cuid())
  registrationNo   String       @unique
  name             String
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  enrollmentDate   DateTime     @default(now())
  emergencyContactName String?
  emergencyContactPhone String?
  curriculum       String       // IB programme: PYP, MYP, or DP
  parentId         String?
  parent           Parent?      @relation(fields: [parentId], references: [id])
  classroomId      String?
  classroom        Classroom?   @relation(fields: [classroomId], references: [id])
  medicalNotes     String?
  bloodGroup       String?
  learningNeeds    String?
  isActive         Boolean      @default(true)
  userId           String?      @unique
  user             User?        @relation("StudentUser", fields: [userId], references: [id])
  // New Demographic & Family Fields
  medium           String?
  groupCode        String?
  nationality      String?
  religion         String?
  community        String?
  subCaste         String?
  motherTongue     String?
  motherName       String?
  motherOccupation String?
  motherMonthlyIncome String?
  fatherName       String?
  
  attendances      Attendance[]
  grades           Grade[]
  homeworkSubmits  HomeworkSubmission[]
  invoices         FeeInvoice[]
  behaviorIncidents BehaviorIncident[]
  walletTransactions WalletTransaction[]
  clubMemberships   ClubMembership[]
  clinicVisits     ClinicVisit[]
  quizAttempts     QuizAttempt[]
  hostelRecord     HostelStudent?
  alumniRecord     Alumni?
  iepPlans         IEPPlan[]
  ibSubjects       IBSubjectRecord[]
  ibCore           IBCoreRecord[]
  assessmentResults AssessmentResult[]
}

model Classroom {
  id          String    @id @default(cuid())
  name        String    // e.g., 9A
  gradeLevel  Int       // e.g., 9
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  
  students    Student[]
  homeworks   Homework[]
  timetable   TimetableEntry[]
  quizzes     Quiz[]
}

model Subject {
  id          String    @id @default(cuid())
  name        String    // e.g., Biology
  code        String    @unique
  
  grades      Grade[]
  homeworks   Homework[]
  timetable   TimetableEntry[]
  quizzes     Quiz[]
}

model Attendance {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date           DateTime
  status         String
  session        String   @default("FULL_DAY") // MORNING, AFTERNOON, FULL_DAY
  isMedicalLeave Boolean  @default(false)
  recordedBy     String   // userId
  createdAt      DateTime @default(now())
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examName    String
  score       Float
  maxScore    Float
  date        DateTime @default(now())
}

model Homework {
  id            String      @id @default(cuid())
  title         String
  description   String
  dueDate       DateTime
  subjectId     String
  subject       Subject     @relation(fields: [subjectId], references: [id])
  classroomId   String
  classroom     Classroom   @relation(fields: [classroomId], references: [id])
  teacherId     String
  teacher       Teacher     @relation(fields: [teacherId], references: [id])
  attachmentUrl String?
  
  submissions   HomeworkSubmission[]
}

model HomeworkSubmission {
  id            String   @id @default(cuid())
  homeworkId    String
  homework      Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content       String
  attachmentUrl String?
  submittedAt   DateTime @default(now())
  grade         Float?
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("Sender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("Receiver", fields: [receiverId], references: [id])
  subject     String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// PHASE 5: NEW FEATURES

model BehaviorIncident {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  type        String   // MERIT or DEMERIT
  category    String   // e.g., "Disruptive", "Helpful", "Late"
  description String
  points      Int
  date        DateTime @default(now())
}

model WalletTransaction {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  type        String   // TOP_UP or PURCHASE
  amount      Float
  description String   // e.g., "Lunch - Pizza", "Parent Top-up"
  date        DateTime @default(now())
}

model Club {
  id          String   @id @default(cuid())
  name        String
  description String
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  members     ClubMembership[]
  activities  ClubActivity[]
}

model ClubActivity {
  id          String   @id @default(cuid())
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title       String
  type        String   // MEETING, COMPETITION, WORKSHOP, TRIP, SERVICE, EVENT
  date        DateTime
  location    String?
  description String?
  outcome     String?  // filled in after the activity, e.g. "Won 2nd place"
}

model ClubMembership {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id])
  joinedAt    DateTime @default(now())
}

model ClinicVisit {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  reason      String
  treatment   String
  notes       String?
  date        DateTime @default(now())
}

model LeaveRequest {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  appliedAt   DateTime @default(now())
}

model TimetableEntry {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  dayOfWeek   Int       // 1 = Monday, 5 = Friday
  period      Int
  startTime   String    // "08:00"
  endTime     String    // "08:45"
  room        String?
}

model FeeInvoice {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  amount      Float
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  transactions PaymentTransaction[]
}

model PaymentTransaction {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // UPI, CARD
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())
}

// PHASE 7: ENTERPRISE MODULES

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  isRead      Boolean  @default(false)
  type        String   @default("INFO") // INFO, ALERT, SUCCESS
  createdAt   DateTime @default(now())
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id])
  dueDate     DateTime
  createdAt   DateTime @default(now())

  // Exam Engine fields
  examType         String    @default("QUIZ") // UNIT_TEST, MIDTERM, FINAL, QUIZ, PRACTICAL, VIVA, PROJECT
  timeLimitMinutes Int?      // null = untimed
  totalMarks       Int       @default(0)
  status           String    @default("DRAFT") // DRAFT, PUBLISHED, PENDING_MODERATION, MODERATED, GRADES_RELEASED
  moderatedByTeacherId String?
  moderatedByTeacher   Teacher? @relation("ModeratedQuizzes", fields: [moderatedByTeacherId], references: [id])
  moderatedAt      DateTime?
  gradesReleasedAt DateTime?

  questions   Question[]
  attempts    QuizAttempt[]
}

model Question {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text        String
  type        String   @default("MCQ") // MCQ, SHORT_ANSWER, ESSAY
  options     String?  // JSON string of options ["A", "B", "C", "D"], null for essay/short answer
  correctIdx  Int?     // Index of correct option (0-3), null for essay/short answer
  points      Int      @default(1)
  difficulty  String?  // EASY, MEDIUM, HARD
  bloomsLevel String?  // Remember, Understand, Apply, Analyze, Evaluate, Create
  rubricCriteria String? // JSON array of {criterion, maxPoints} for essay/short answer grading

  responses   QuizResponse[]
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score       Int
  totalScore  Int
  submittedAt DateTime @default(now())

  // Exam Engine fields
  startedAt      DateTime?
  autoSubmitted  Boolean   @default(false)
  status         String    @default("SUBMITTED") // IN_PROGRESS, SUBMITTED, GRADED, RELEASED
  questionOrder  String?   // JSON array of question ids in randomized order shown to this student

  responses      QuizResponse[]
}

model QuizResponse {
  id            String      @id @default(cuid())
  attemptId     String
  attempt       QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIdx   Int?        // for MCQ
  textAnswer    String?     // for short answer / essay
  marksAwarded  Float?
  rubricScores  String?     // JSON array of {criterion, points} awarded
  feedback      String?
  gradedByTeacherId String?
}

model Alumni {
  id               String   @id @default(cuid())
  studentId        String   @unique
  student          Student  @relation(fields: [studentId], references: [id])
  graduationYear   Int
  finalProgramme   String   // PYP, MYP, or DP
  finalDpScore     Int?     // out of 45, DP graduates only
  university       String?
  courseOfStudy    String?
  country          String?
  currentStatus    String?  // STUDYING, WORKING, GAP_YEAR, OTHER
  achievements     String?
  linkedinUrl      String?
  isFeatured       Boolean  @default(false) // shown on the achievement wall
  createdAt        DateTime @default(now())
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  category    String   // LAPTOP, IPAD, LAB_EQUIPMENT
  serialNo    String   @unique
  status      String   @default("AVAILABLE") // AVAILABLE, CHECKED_OUT, MAINTENANCE
  createdAt   DateTime @default(now())
  
  checkouts   AssetCheckout[]
}

model AssetCheckout {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  userId      String   // Can be student or teacher
  user        User     @relation(fields: [userId], references: [id])
  checkoutDate DateTime @default(now())
  returnDate  DateTime?
  status      String   @default("ACTIVE") // ACTIVE, RETURNED
}

model HostelRoom {
  id          String   @id @default(cuid())
  roomNumber  String   @unique
  block       String
  capacity    Int
  type        String   // AC, NON_AC
  occupants   HostelStudent[]
}

model HostelStudent {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id])
  roomId      String
  room        HostelRoom @relation(fields: [roomId], references: [id])
  joinedAt    DateTime @default(now())
}

model FeeStructure {
  id          String   @id @default(cuid())
  name        String   // e.g., "Grade 10 Annual Tuition"
  amount      Float
  gradeLevel  String?  // Optional, if it applies to a specific grade
  academicYear String
  createdAt   DateTime @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  name        String   // e.g., "Chemistry Lab 1", "Projector A", "The Great Gatsby"
  type        String   // e.g., "FACILITY", "EQUIPMENT", "LIBRARY_BOOK"
  status      String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE
  capacity    Int?     // For rooms
  bookings    ResourceBooking[]
}

model ResourceBooking {
  id          String   @id @default(cuid())
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id])
  userId      String   // Can be teacher or student
  user        User     @relation(fields: [userId], references: [id])
  startTime   DateTime
  endTime     DateTime
  purpose     String
  status      String   @default("APPROVED") // PENDING, APPROVED, CANCELLED
}

// Learning Needs & IEP (PRD Module 01)

model IEPPlan {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  caseManagerId  String?
  caseManager    Teacher?  @relation("IEPCaseloads", fields: [caseManagerId], references: [id])
  needType       String    // e.g. Dyslexia, ADHD, Autism Spectrum, Gifted & Talented, EAL
  status         String    @default("ACTIVE") // ACTIVE, UNDER_REVIEW, ARCHIVED
  summary        String
  accommodations String?   // newline-separated list of classroom accommodations
  reviewDate     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  goals          IEPGoal[]
}

model IEPGoal {
  id         String    @id @default(cuid())
  planId     String
  plan       IEPPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  title      String
  targetDate DateTime?
  progress   Int       @default(0) // 0-100
  status     String    @default("IN_PROGRESS") // IN_PROGRESS, ACHIEVED, AT_RISK
  notes      String?
  createdAt  DateTime  @default(now())
}

// Teacher Professional Development & Appraisal (PRD Module 02)

model PDRecord {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  title         String
  type          String   // WORKSHOP, CERTIFICATION, COURSE, CONFERENCE
  provider      String?
  hours         Int
  dateCompleted DateTime @default(now())
  notes         String?
}

model Observation {
  id              String   @id @default(cuid())
  teacherId       String
  teacher         Teacher  @relation("ObservedTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  observerName    String
  date            DateTime @default(now())
  className       String?
  focusArea       String?  // e.g. ATL skill integration, Inquiry-based learning
  planningScore   Int      // IB 1-7 scale
  deliveryScore   Int
  engagementScore Int
  assessmentScore Int
  strengths       String?
  growthAreas     String?
  status          String   @default("FINAL") // DRAFT, FINAL
}

// IB Academic Records (criterion-based assessment, DP/MYP)

model IBSubjectRecord {
  id             String  @id @default(cuid())
  studentId      String
  student        Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectName    String  // e.g. "Mathematics: Analysis & Approaches"
  subjectGroup   Int     // IB groups 1-6
  level          String  // HL, SL (DP) or MYP
  currentGrade   Int?    // 1-7
  predictedGrade Int?    // 1-7
  critA          Int?    // MYP criteria 0-8
  critB          Int?
  critC          Int?
  critD          Int?
  teacherComment String?
  term           String  @default("Term 1 2026-27")
}

model IBCoreRecord {
  id              String  @id @default(cuid())
  studentId       String
  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  element         String  // TOK, EE, CAS
  title           String? // EE title / TOK essay title
  status          String  @default("IN_PROGRESS") // NOT_STARTED, IN_PROGRESS, SUBMITTED, COMPLETE
  grade           String? // A-E for TOK/EE
  creativityHours Int     @default(0)
  activityHours   Int     @default(0)
  serviceHours    Int     @default(0)
  reflections     Int     @default(0)
}

model IBExamSession {
  id              String   @id @default(cuid())
  programme       String   // DP, MYP
  session         String   // e.g. "November 2026 Mock", "May 2027"
  subjectName     String
  level           String?  // HL / SL for DP
  paper           String   // Paper 1, Paper 2, Paper 3, On-screen exam, ePortfolio
  date            DateTime
  durationMinutes Int
  room            String?
  notes           String?  // e.g. "Calculator allowed"
}

// Lesson planning with IB curriculum alignment (PRD M01)

model LessonPlan {
  id              String   @id @default(cuid())
  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  title           String
  subjectName     String
  className       String?
  date            DateTime
  durationMinutes Int      @default(60)
  ibUnit          String?  // MYP unit of inquiry / DP syllabus topic
  atlSkills       String?  // comma-separated ATL skill categories
  learnerProfile  String?  // comma-separated IB learner profile attributes
  objectives      String?
  activities      String?
  resources       String?
  assessment      String?  // formative/summative + criteria
  status          String   @default("PLANNED") // DRAFT, PLANNED, DELIVERED
  subPlan         String?  // generated substitute-teacher plan
  createdAt       DateTime @default(now())
}

// Academic calendar with national-calendar sync (PRD M01)

model AcademicEvent {
  id        String    @id @default(cuid())
  title     String
  type      String    // TERM, HOLIDAY, NATIONAL_HOLIDAY, EXAM_WINDOW, EVENT
  startDate DateTime
  endDate   DateTime?
  source    String    @default("SCHOOL") // SCHOOL, NATIONAL, IB
  notes     String?
}

// Subject resources and assessment history (student all-in-one subject view)

model SubjectResource {
  id          String  @id @default(cuid())
  subjectName String  // matches IBSubjectRecord.subjectName
  programme   String  @default("DP") // DP, MYP, PYP
  title       String
  type        String  // NOTES, PAST_PAPER, VIDEO, LINK, WORKSHEET
  description String?
  url         String?
  addedBy     String? // teacher name
  createdAt   DateTime @default(now())
}

model AssessmentResult {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectName String
  title       String   // e.g. "Unit Test 2: Mechanics"
  type        String   // FORMATIVE, SUMMATIVE, MOCK, IA_DRAFT, ORAL
  date        DateTime
  grade       Int      // IB 1-7
  maxGrade    Int      @default(7)
  comment     String?
  term        String   @default("Term 1 2026-27")
}
